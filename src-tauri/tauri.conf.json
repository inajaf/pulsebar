{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pulsebar",
  "version": "0.1.1",
  "identifier": "com.eldar.performance-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pulsebar",
        "width": 384,
        "height": 620,
        "minWidth": 340,
        "minHeight": 540,
        "resizable": true,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
